{
  "name": "@amibeingpwned/pgp",
  "description": "PGP Tools - Encrypt, Decrypt & Sign",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build:wasm": "cd gpg-wasm && wasm-pack build --target web --release && cp pkg/gpg_wasm_bg.wasm ../public/gpg_wasm_bg.wasm",
    "build": "pnpm build:wasm && wxt build && node scripts/audit-network.mjs",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@amibeingpwned/ui": "workspace:*",
    "date-fns": "^4.1.0",
    "fflate": "^0.8.2",
    "lucide-react": "^0.563.0",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@amibeingpwned/eslint-config": "workspace:*",
    "@amibeingpwned/prettier-config": "workspace:*",
    "@amibeingpwned/tailwind-config": "workspace:*",
    "@amibeingpwned/tsconfig": "workspace:*",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@tailwindcss/vite": "catalog:",
    "@types/chrome": "^0.1.36",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@wxt-dev/module-react": "^1.1.5",
    "eslint": "catalog:",
    "eslint-plugin-turbo": "^2.9.2",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:",
    "vite-plugin-wasm": "^3.6.0",
    "wxt": "^0.20.14"
  },
  "prettier": "@amibeingpwned/prettier-config"
}
